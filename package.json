{
  "name": "turbo-next-cli",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "start:cli": "turbo --filter=next-cli start",
    "build:cli": "turbo --filter=next-cli build",
    "dev:cli": "turbo --filter=next-cli dev",
    "ui:add": "pnpm --filter @repo/ui ui:add",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  }
}
